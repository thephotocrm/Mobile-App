{
  "expo": {
    "name": "Argo Studio",
    "slug": "thephotocrm",
    "owner": "austinpach2014",
    "version": "1.0.0",
    "privacy": "public",
    "privacyPolicyUrl": "https://app.thephotocrm.com/privacy",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "thephotocrm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "appleTeamId": "U8642G7Q84",
      "supportsTablet": true,
      "bundleIdentifier": "app.replit.pixelpot",
      "buildNumber": "7",
      "deploymentTarget": "15.0",
      "usesAppleSignIn": true,
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.thephotocrm.app",
      "versionCode": 1,
      "targetSdkVersion": 34,
      "compileSdkVersion": 34,
      "adaptiveIcon": {
        "backgroundColor": "#8B4565",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#8B4565",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "googleClientId": "905635479138-ut0qbr1417vh2pj3u1i0tbgin1h89g0s.apps.googleusercontent.com",
      "eas": {
        "projectId": "7e10e045-b3f4-4acd-beb8-87af60faf425"
      }
    }
  }
}
